# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE - Personal Website
# =============================================================================
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# WEATHER API (for temperature display)
# -----------------------------------------------------------------------------
# Get a free API key from https://www.weatherapi.com/
# Replace "YourCity" with your actual city name

NEXT_PUBLIC_WEATHERAPI_KEY=
NEXT_PUBLIC_WEATHERAPI_CITY=

# -----------------------------------------------------------------------------
# MYANIMELIST API
# -----------------------------------------------------------------------------
MAL_CLIENT_ID=
MAL_USERNAME=

# -----------------------------------------------------------------------------
# LINKEDIN OAUTH
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GITHUB OAUTH
# -----------------------------------------------------------------------------
GITHUB_ID=
GITHUB_SECRET=

# -----------------------------------------------------------------------------
# DISCORD WEBHOOK
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# NEXTAUTH
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# METRICS PAGE INTEGRATIONS
# -----------------------------------------------------------------------------
# GitHub username for stats
GITHUB_USERNAME=
NEXT_PUBLIC_GITHUB_USERNAME=

# GitHub Personal Access Token for authenticated API calls (higher rate limit)
# Create one at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=

# LeetCode username (uses leetcode-api-faisalshohag)
LEETCODE_USERNAME=

# WakaTime API key
WAKATIME_API_KEY=

# Duolingo username
DUOLINGO_USERNAME=

# =============================================================================
# GAMES PAGE
# =============================================================================
# Epic Games support only (Steam frozen)
STEAM_ENABLED=false

# -----------------------------------------------------------------------------
# DATABASE (Neon Postgres — guestbook)
# -----------------------------------------------------------------------------
# Create a free project at https://neon.tech, then run: npx prisma db push
DATABASE_URL=

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 (object storage — gallery photos etc.)
# -----------------------------------------------------------------------------
# Create a bucket + S3 API token at https://dash.cloudflare.com > R2 > Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_API_TOKEN=
R2_BUCKET_NAME=
# Public base URL for serving objects (custom domain, e.g. https://cdn.example.com, or the bucket's r2.dev URL)
NEXT_PUBLIC_R2_PUBLIC_URL=