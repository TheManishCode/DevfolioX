# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE - Personal Website
# =============================================================================
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# SPOTIFY INTEGRATION
# -----------------------------------------------------------------------------
# Get these from https://developer.spotify.com/dashboard
# See implementation_plan.md for detailed setup instructions

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# WEATHER API (for temperature display)
# -----------------------------------------------------------------------------
# Get a free API key from https://www.weatherapi.com/
# Replace "YourCity" with your actual city name

NEXT_PUBLIC_WEATHERAPI_KEY=
NEXT_PUBLIC_WEATHERAPI_CITY=

# -----------------------------------------------------------------------------
# MYANIMELIST API
# -----------------------------------------------------------------------------
MAL_CLIENT_ID=
MAL_USERNAME=

# -----------------------------------------------------------------------------
# LINKEDIN OAUTH
# -----------------------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# GITHUB OAUTH
# -----------------------------------------------------------------------------
GITHUB_ID=
GITHUB_SECRET=

# -----------------------------------------------------------------------------
# DISCORD WEBHOOK
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# NEXTAUTH
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# METRICS PAGE INTEGRATIONS
# -----------------------------------------------------------------------------
# GitHub username for stats
GITHUB_USERNAME=
NEXT_PUBLIC_GITHUB_USERNAME=

# GitHub Personal Access Token for authenticated API calls (higher rate limit)
# Create one at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=

# LeetCode username (uses leetcode-api-faisalshohag)
LEETCODE_USERNAME=

# WakaTime API key
WAKATIME_API_KEY=

# Duolingo username
DUOLINGO_USERNAME=

# =============================================================================
# GAMES PAGE
# =============================================================================
# Epic Games support only (Steam frozen)
STEAM_ENABLED=false